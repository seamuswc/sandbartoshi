[Unit]
Description=Sandbartoshi property map
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/sandbartoshi
EnvironmentFile=/var/www/sandbartoshi/.env
ExecStart=/usr/bin/node /var/www/sandbartoshi/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
